        summary:hover { background-color: #f8f9fa; }
        summary::-webkit-details-marker { display: none; }
        .feed-info { display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0; }
        .feed-title-text { font-size: 16px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .feed-meta-count { display: flex; align-items: center; gap: 8px; font-size: 12px; flex-shrink: 0; }
