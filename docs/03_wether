        .card-content { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: flex-start; }
        .entry-thumbnail { width: 120px; height: 90px; object-fit: cover; border-radius: 8px; flex-shrink: 0; border: 1px solid #eee; }

