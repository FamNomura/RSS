        }
        .nav-link {
            color: #ecf0f1;
            text-decoration: none;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 13px;
            font-weight: 600;
            opacity: 0.85;
            transition: all 0.2s;
            background-color: rgba(255,255,255,0.1);
            white-space: nowrap;
        }
        .nav-link:hover { opacity: 1; background-color: rgba(255,255,255,0.2); }
