        .feed-favicon { width: 14px; height: 14px; border-radius: 2px; }
        .entry-source { font-weight: 600; color: #555; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
        .entry-time { border-left: 1px solid #ddd; padding-left: 8px; white-space: nowrap; }
        
        .entry-title { font-size: 16px; margin: 0 0 6px 0; line-height: 1.4; }
        .entry-title a { text-decoration: none; color: var(--text-main); font-weight: bold; }
        .entry-title a:hover { color: var(--accent); text-decoration: underline; }

