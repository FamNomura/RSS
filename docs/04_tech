    <div id="backToTop" title="トップへ戻る">↑</div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // 修正箇所: ジャンプボタン連動のスクロール＆アコーディオン自動展開ロジック
            document.querySelectorAll('.jump-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('href').substring(1);
                    const targetSection = document.getElementById(targetId);
                    
                    if (targetSection) {
                        // ジャンプ先のセクション内にあるアコーディオンをすべて開く
                        targetSection.querySelectorAll('details').forEach(details => {
                            details.open = true;
                        });
                        
                        // ヘッダーの高さを考慮して少しずらしてスクロール
                        const headerOffset = 70;
                        const elementPosition = targetSection.getBoundingClientRect().top;
                        const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
                        
                        window.scrollTo({
                             top: offsetPosition,
                             behavior: "smooth"
                        });
                    }
                });
            });

            // 既読管理
            const STORAGE_KEY = 'rss_read_items';
            let readItems = new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'));
            const entryItems = document.querySelectorAll('.entry-item');
            
            entryItems.forEach(item => {
                const link = item.dataset.link;
                if (readItems.has(link)) {
                    item.classList.add('read');
                }
                const anchor = item.querySelector('a.entry-link');
                if(anchor) {
                    anchor.addEventListener('click', function() {
                        // 同じURLを持つすべての記事（タイムラインとサイト別の両方）を既読にする
                        document.querySelectorAll(`.entry-item[data-link="${link}"]`).forEach(el => {
                            el.classList.add('read');
                        });
                        readItems.add(link);
                        if (readItems.size > 1000) {
                            const array = Array.from(readItems);
                            readItems = new Set(array.slice(array.length - 1000));
                        }
                        localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(readItems)));
                    });
                }
            });

            // 検索・絞り込み
            const searchToggle = document.getElementById('searchToggle');
            const searchInput = document.getElementById('searchInput');
            
            if (searchToggle && searchInput) {
                searchToggle.addEventListener('click', () => {
                    searchInput.classList.toggle('active');
                    if(searchInput.classList.contains('active')) {
                        searchInput.focus();
                    }
                });
            }

            entryItems.forEach(entry => {
                const titleLink = entry.querySelector('.entry-title a');
                const summaryDiv = entry.querySelector('.entry-summary');
                if(titleLink && summaryDiv){
                    entry.dataset.originalTitleHtml = titleLink.innerHTML;
                    entry.dataset.originalSummaryHtml = summaryDiv.innerHTML;
                }
            });

            searchInput.addEventListener('input', function(e) {
                const term = e.target.value.trim().toLowerCase();

                if (term === '') {
                    entryItems.forEach(entry => {
                        entry.style.display = '';
                        const titleLink = entry.querySelector('.entry-title a');
                        const summaryDiv = entry.querySelector('.entry-summary');
                        if(titleLink && entry.dataset.originalTitleHtml) titleLink.innerHTML = entry.dataset.originalTitleHtml;
                        if(summaryDiv && entry.dataset.originalSummaryHtml) summaryDiv.innerHTML = entry.dataset.originalSummaryHtml;
                    });
                    
                    // 検索クリア時は全アコーディオンを閉じて元の目次状態に戻す
                    document.querySelectorAll('details.feed-section').forEach(sec => {
                        sec.style.display = '';
                        sec.open = false; 
                    });
                    return;
                }

                entryItems.forEach(entry => {
                    const titleText = (entry.dataset.title || '').toLowerCase();
                    const summaryText = (entry.dataset.summary || '').toLowerCase();

                    if (titleText.includes(term) || summaryText.includes(term)) {
                        entry.style.display = '';
                        highlightText(entry, term);
                    } else {
                        entry.style.display = 'none';
                    }
                });

                // 修正箇所: トピック・タイムライン・サイト別のすべてのアコーディオンを横断して制御
                document.querySelectorAll('details.feed-section').forEach(section => {
                    // クラスが .list-item (サイト別・トピック別) または .card (タイムライン) のものを探す
                    const visibleItems = Array.from(section.querySelectorAll('.entry-item')).filter(el => el.style.display !== 'none');
                    if(visibleItems.length === 0) {
                        section.style.display = 'none';
                    } else {
                        section.style.display = '';
                        section.open = true; // ヒットしたアコーディオンは自動で開く
                    }
                });
            });

            function highlightText(entry, term) {
                try {
                    const regex = new RegExp(`(${escapeRegExp(term)})`, 'gi');
                    const highlightMark = '<mark>$1</mark>';
                    const titleLink = entry.querySelector('.entry-title a');
                    const summaryDiv = entry.querySelector('.entry-summary');
                    
                    if(titleLink && entry.dataset.originalTitleHtml) {
                        titleLink.innerHTML = entry.dataset.originalTitleHtml.replace(regex, highlightMark);
                    }
                    if(summaryDiv && entry.dataset.originalSummaryHtml) {
                        summaryDiv.innerHTML = entry.dataset.originalSummaryHtml.replace(regex, highlightMark);
                    }
                } catch(e) { console.error(e); }
            }

            function escapeRegExp(string) {
                return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            }

            const backToTopBtn = document.getElementById('backToTop');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 300) {
                    backToTopBtn.classList.add('show');
                } else {
                    backToTopBtn.classList.remove('show');
                }
            });
            backToTopBtn.addEventListener('click', () => {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        });
    </script>
